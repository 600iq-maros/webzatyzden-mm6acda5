# SMTP Configuration for sending emails from info@webzatyzden.sk
# Copy this file to .env.local and fill in your WebSupport SMTP credentials
# Docs: https://www.websupport.sk/podpora/kb/postove-protokoly/

SMTP_HOST=smtp.m1.websupport.sk
SMTP_PORT=465
SMTP_USER=info@webzatyzden.sk
SMTP_PASS=your-email-password-here
